---
const year = new Date().getFullYear();
const linkedInUrl = 'https://linkedin.com/in/your-profile'; // TODO: Update with your LinkedIn URL
---

<footer class="bg-slate-900 text-slate-400 py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">

      <!-- Brand -->
      <div>
        <p class="text-white font-bold text-lg">Edward Iliescu</p>
        <p class="text-sm mt-1">Full-stack Developer & SaaS Builder</p>
      </div>

      <!-- Nav links -->
      <nav>
        <ul class="flex flex-wrap items-center gap-6 text-sm">
          <li><a href="#services" class="hover:text-white transition-colors">Services</a></li>
          <li><a href="#stack" class="hover:text-white transition-colors">Stack</a></li>
          <li><a href="#contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </nav>

      <!-- Social -->
      <div class="flex items-center gap-4">
        <a
          href={linkedInUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-9 h-9 rounded-full bg-slate-800 hover:bg-indigo-600 flex items-center justify-center transition-colors duration-200"
        >
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="border-t border-slate-800 mt-10 pt-8 text-center text-sm">
      <p>&copy; {year} Edward Iliescu. All rights reserved.</p>
    </div>
  </div>
</footer>
