---
const featured = {
  category: 'E-commerce Platform · Shopify + Laravel',
  title: 'Custom Order-Management Platform for a Shopify Retailer',
  intro:
    'A retailer needed order workflows, multilingual customer communications, and automation beyond what their e-commerce platform offered out of the box.',
  blocks: [
    {
      label: 'The Problem',
      text: 'The off-the-shelf store couldn\'t sync orders into internal systems, send locale-aware transactional email, or give customers self-serve order management.',
    },
    {
      label: 'What I Built',
      items: [
        'A custom integration layer syncing orders, products, and webhooks in real time',
        'A webhook-driven order pipeline that reconciles fulfillment and cancellation state',
        'A multilingual transactional email engine driven by customer locale',
        'A self-serve cancellation flow with business-rule safeguards',
        'Fully automated cloud provisioning and deployment',
      ],
    },
    {
      label: 'The Result',
      text: 'Later re-architected onto a modern full-stack setup with managed background queues, built to scale with order volume.',
    },
  ],
  tags: ['Laravel', 'Shopify API', 'React', 'Inertia', 'TypeScript', 'Redis', 'AWS', 'Queues'],
};

const cards = [
  {
    category: 'Legacy Modernization',
    text: 'Refactored sprawling legacy code into clean, single-responsibility services — then led the rewrite onto a modern, maintainable stack.',
    tags: ['PHP', 'Laravel', 'Refactoring'],
  },
  {
    category: 'DevOps & Infrastructure',
    text: 'Automated server provisioning and deployment — application runtime, database, cache, queue workers, web server, firewall, and scheduler on cloud infrastructure.',
    tags: ['AWS', 'Nginx', 'Redis', 'Linux'],
  },
];
---

<section id="work" class="py-24 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-indigo-600 font-semibold text-sm uppercase tracking-widest mb-3">My Work</p>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight mb-4">
        Selected Work
      </h2>
      <p class="text-lg text-slate-500 max-w-xl">
        A look at the kind of problems I solve — from first commit to production.
      </p>
    </div>

    <!-- Featured case study -->
    <div class="group bg-slate-50 border border-slate-200 rounded-2xl p-8 sm:p-10 mb-6 hover:border-indigo-300 hover:shadow-lg hover:shadow-indigo-50 transition-all duration-300">
      <p class="text-indigo-600 font-semibold text-xs uppercase tracking-widest mb-4">{featured.category}</p>
      <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight mb-4">{featured.title}</h3>
      <p class="text-slate-500 leading-relaxed max-w-3xl mb-8">{featured.intro}</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        {featured.blocks.map((block) => (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">{block.label}</p>
            {block.text && <p class="text-sm text-slate-600 leading-relaxed">{block.text}</p>}
            {block.items && (
              <ul class="flex flex-col gap-2">
                {block.items.map((item) => (
                  <li class="flex gap-2 text-sm text-slate-600 leading-relaxed">
                    <svg class="w-4 h-4 text-indigo-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>

      <div class="flex flex-wrap gap-2">
        {featured.tags.map((tag) => (
          <span class="text-xs font-medium text-slate-600 bg-white border border-slate-200 px-3 py-1.5 rounded-lg">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Supporting cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {cards.map((card) => (
        <div class="group bg-slate-50 border border-slate-200 rounded-2xl p-8 hover:border-indigo-300 hover:shadow-lg hover:shadow-indigo-50 transition-all duration-300 hover:-translate-y-1">
          <p class="text-indigo-600 font-semibold text-xs uppercase tracking-widest mb-3">{card.category}</p>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">{card.text}</p>
          <div class="flex flex-wrap gap-2">
            {card.tags.map((tag) => (
              <span class="text-xs font-medium text-slate-600 bg-white border border-slate-200 px-3 py-1.5 rounded-lg">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
