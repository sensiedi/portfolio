---
---

<section
  id="hero"
  class="min-h-screen flex flex-col justify-center pt-24 pb-16 px-6"
>
  <div class="max-w-6xl mx-auto w-full">
    <div class="max-w-3xl">
      <!-- Availability badge -->
      <div class="animate-fade-up animate-fade-up-delay-1 inline-flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-medium px-3 py-1.5 rounded-full mb-8">
        <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>
        Available for new projects
      </div>

      <!-- Name -->
      <h1 class="animate-fade-up animate-fade-up-delay-2 text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.1] mb-6">
        Hi, I'm <span class="text-indigo-600">Edward</span><br />
        Iliescu.
      </h1>

      <!-- Tagline -->
      <p class="animate-fade-up animate-fade-up-delay-3 text-xl sm:text-2xl text-slate-500 font-light leading-relaxed mb-10 max-w-2xl">
        Full-stack developer building <span class="text-slate-700 font-medium">SaaS products</span>,
        <span class="text-slate-700 font-medium">Shopify & e-commerce</span> solutions,
        and complex <span class="text-slate-700 font-medium">third-party integrations</span>.
      </p>

      <!-- CTAs -->
      <div class="animate-fade-up animate-fade-up-delay-4 flex flex-wrap gap-4">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3.5 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-indigo-200 hover:-translate-y-0.5"
        >
          Get in touch
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center gap-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-6 py-3.5 rounded-xl transition-all duration-200"
        >
          View services
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-20 flex items-center gap-3 text-slate-400 text-sm">
      <div class="w-px h-12 bg-gradient-to-b from-transparent to-slate-300"></div>
      <span>Scroll to explore</span>
    </div>
  </div>
</section>
